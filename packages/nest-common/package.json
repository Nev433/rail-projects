{
  "name": "rail-nest-common",
  "version": "0.1.0",
  "description": "Shared NestJS infrastructure for the rail-projects workspace: ApiKeyGuard, @Public, Neo4jExceptionFilter, ValidationPipe + Throttler factories.",
  "keywords": [
    "rail",
    "rail-projects",
    "nestjs"
  ],
  "homepage": "https://github.com/Nev433/rail-projects#readme",
  "bugs": {
    "url": "https://github.com/Nev433/rail-projects/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nev433/rail-projects.git",
    "directory": "packages/nest-common"
  },
  "license": "MIT",
  "author": "Craig Nevins (Nev433)",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run postbuild:cleanup",
    "prepare": "npm run build",
    "_comment_cleanup": "After tsc, remove peer-dep runtimes from this package's own node_modules so consumers' copies are the ones loaded at runtime. Without this, Node's symlink-resolution walks up into THIS package's node_modules first and finds duplicate @nestjs/* classes, breaking Nest DI (Reflector class identity mismatch). See packages/nest-common/README.md.",
    "postbuild:cleanup": "rm -rf node_modules/@nestjs node_modules/express node_modules/rxjs node_modules/reflect-metadata"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "express": "^5.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "express": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "typescript": "~5.9.2"
  }
}
